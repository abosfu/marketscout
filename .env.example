# MarketScout — environment variable reference
# Copy this file to .env and fill in your values.
# Variables already present in your shell always take precedence over .env.

# ── Required for jobs ingestion (Adzuna provider) ─────────────────────────────
# Sign up at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Optional: ISO 3166-1 alpha-2 country code. Defaults to "ca" (Canada).
ADZUNA_COUNTRY=ca

# ── Required for NL2SQL chat interface ────────────────────────────────────────
# Gemini API key — used by the FastAPI /api/ask endpoint.
# Without this, the backend returns HTTP 503 on every query.
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key

# ── Optional: OpenAI key for LLM strategy generation ─────────────────────────
# If set, generate_strategy() calls GPT-4o-mini instead of the deterministic fallback.
# The pipeline runs fully without this key — omit it to use rule-based scoring only.
OPENAI_API_KEY=your_openai_api_key

# ── Optional: pipeline tuning ─────────────────────────────────────────────────
# Strategy mode: "auto" (default), "mock" (force rule-based), or "llm" (force OpenAI).
MARKETSCOUT_MODE=auto

# Default city when --city is not supplied.
MARKETSCOUT_DEFAULT_CITY=Vancouver

# Maximum headlines to fetch per run. Defaults to 10.
MARKETSCOUT_MAX_HEADLINES=10

# Disk cache TTL in seconds. Defaults to 3600 (1 hour).
MARKETSCOUT_DISK_CACHE_TTL=3600

# Override the cache directory. Defaults to .cache/marketscout/ (relative to cwd).
# MARKETSCOUT_CACHE_DIR=/path/to/cache

# Override the SQLite database path. Defaults to .cache/marketscout/marketscout.db.
# MARKETSCOUT_DB_PATH=/path/to/marketscout.db
